# Copy to .env.local and fill from Supabase Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Project Settings → API Keys → Publishable key (sb_publishable_…). Legacy anon JWT still works if you set NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Server-only — never expose to the browser (redirect + click inserts).
# Prefer new secret keys (sb_secret_…) where offered; legacy service_role JWT still works.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_secret_key

# Used when building absolute short URLs (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
